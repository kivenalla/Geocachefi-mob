# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=nestjs
POSTGRES_POOL_SIZE=10

# JWT
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32
JWT_EXPIRES=1h

# Session
SESSION_SECRET=CHANGE_ME_another_random_secret

# Geocaching.com API (optional — for Groundspeak integration)
CONSUMER_KEY=your_consumer_key
CONSUMER_SECRET=your_consumer_secret

# OAuth
OAUTH_REDIRECT_URI=https://yourdomain.com/api/oauth/callback
FRONTEND_REDIRECT_URI=https://yourdomain.com
FRONTEND_DOMAIN=yourdomain.com

# CORS — comma-separated additional allowed origins
CORS_ALLOWED_DOMAINS=https://yourdomain.com
