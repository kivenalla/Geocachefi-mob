# syntax=docker/dockerfile:1.7
FROM node:20-alpine

ARG CACHE_BUST=2
RUN echo "Cache bust: $CACHE_BUST"
# We'll keep the whole workspace here so ../frontend is available
WORKDIR /workspace

# 1) Copy only package manifests first (cache-friendly)
COPY mock-backend/package*.json mock-backend/
COPY frontend/package*.json frontend/

# 2) Install deps for BOTH backend and frontend
RUN --mount=type=cache,target=/root/.npm \
    npm install --prefix mock-backend && \
    npm install --prefix frontend

# 3) Copy sources for BOTH projects (so it also works without bind mounts)
COPY mock-backend/ mock-backend/
COPY frontend/ frontend/

# 4) Dev env
ENV NODE_ENV=development \
    PORT=4000

# 5) Work from backend dir and expose API port
WORKDIR /workspace/mock-backend
EXPOSE 4000

# CMD to run on start
CMD npm run dev:watch
