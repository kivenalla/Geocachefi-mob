# syntax=docker/dockerfile:1.7
FROM node:20-alpine

WORKDIR /workspace

# 1) Copy only package manifests first (cache-friendly)
COPY new-frontend/package*.json new-frontend/

# 2) Install deps
RUN --mount=type=cache,target=/root/.npm \
    npm install --prefix new-frontend

# 3) Copy sources
COPY new-frontend/ new-frontend/

# 4) Dev env
ENV NODE_ENV=development \
    PORT=3000

# 5) Work from new-frontend dir and expose new-frontend port
WORKDIR /workspace/new-frontend
EXPOSE 3000

# CMD to run on start
CMD npm run dev
